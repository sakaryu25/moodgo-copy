{
  "expo": {
    "name": "MoodGo",
    "slug": "moodgo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "moodgo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.moodgo.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "現在地周辺のおすすめスポットを探すために位置情報を使用します。",
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationQueriesSchemes": [
          "comgooglemaps",
          "googlemaps"
        ]
      }
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "現在地周辺のおすすめスポットを探すために位置情報を使用します。"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "スポットの写真投稿や、グループ・プロフィールのアイコン設定のために写真ライブラリにアクセスします。"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1a0a00",
          "dark": {
            "backgroundColor": "#1a0a00"
          }
        }
      ],
      "expo-notifications",
      "@sentry/react-native",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#FAF3EC"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5d56f249-ac07-45f5-81dc-71b8b1c9d4ad"
      }
    },
    "owner": "krkr"
  }
}
